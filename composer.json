{
    "name": "rubricate/element",
    "description": "Assists in creating elements: HTML and XML",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Estefanio N Santos",
            "email": "estefanions@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "keywords": [
        "rubricatephp",
        "rubricate-component",
        "element",
        "html",
        "xml",
        "fluent-interface",
        "html-builder",
        "markup-generator",
        "oop",
        "clean-code"
    ],
    "support": {
        "docs": "https://rubricate.github.io/components/element",
        "source": "https://github.com/rubricate/element",
        "issues": "https://github.com/rubricate/element/issues"
    },
    "autoload": {
        "psr-4": {
            "Rubricate\\Element\\": "Rubricate/Element/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    }
}
